{
  "manifest_version": 3,
  "name": "Sovereign Wallet",
  "version": "0.1.0",
  "description": "Bitcoin wallet with privacy-first design. Connect to your own Electrum/Fulcrum node.",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
