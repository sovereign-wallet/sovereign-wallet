# Sovereign Wallet — Environment Variables
# Copy this file to .env and fill in your values.

# Your Bitcoin node Fulcrum/Electrum server (WebSocket SSL)
# Example: wss://192.168.0.184:50002
VITE_DEFAULT_NODE_URL=

# Tor hidden service address for your node (optional)
# Example: wss://abc123def456.onion:50002
VITE_NODE_ONION_ADDRESS=

# WireGuard server public key for Family Node invitations
VITE_WIREGUARD_PUBLIC_KEY=

# Anthropic API key for AI privacy advisor (optional)
# Get one at: https://console.anthropic.com/
# Can also be set from Settings inside the extension.
VITE_ANTHROPIC_API_KEY=

# Donation addresses (optional — remove if not needed)
VITE_DONATION_BTC_ADDRESS=
VITE_DONATION_LIGHTNING_ADDRESS=
